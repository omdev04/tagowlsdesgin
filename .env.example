# AI Template Assistant (server-side only)
# Use your NVIDIA NIM / OpenAI-compatible endpoint URL.
# Example: https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_AI_ENDPOINT=
NVIDIA_AI_API_KEY=

# Optional override. Default is meta/llama-3.1-70b-instruct
NVIDIA_AI_MODEL=meta/llama-3.1-70b-instruct

# RTC / Meet frontend
NEXT_PUBLIC_RTC_BACKEND_URL=https://rtc-backend-seven.vercel.app
NEXT_PUBLIC_MEET_RINGTONE_URL=/sounds/minion_beep.mp3
